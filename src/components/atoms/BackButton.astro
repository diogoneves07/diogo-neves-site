---
// Returns to the previous page. Hidden when there is no history to go back to.
---

<button
  id="back-button"
  type="button"
  title="Voltar para a página anterior..."
  aria-label="Voltar para a página anterior"
  transition:persist>&#129176;</button>

<style>
  button {
    position: fixed;
    left: 2%;
    bottom: 3%;
    padding: 5px;
    width: 90px;
    height: 40px;
    color: #d4d4d4;
    font-size: 32px;
    line-height: 35px;
    border-radius: 10px 0 10px;
    background-color: var(--brand-blue);
    border: solid var(--accent);
    border-width: 0 1px;
    cursor: pointer;
    z-index: 1000;
  }

  button:hover {
    color: var(--accent);
  }
</style>

<script>
  // The button persists across View Transitions (transition:persist), so the
  // click listener is attached once; only its visibility is re-evaluated per
  // navigation as the history length changes.
  function updateVisibility(): void {
    const button = document.getElementById("back-button");
    if (button) button.style.display = window.history.length > 1 ? "" : "none";
  }

  document
    .getElementById("back-button")
    ?.addEventListener("click", () => window.history.back());
  updateVisibility();
  document.addEventListener("astro:after-swap", updateVisibility);
</script>
