---
// Toggles the document theme and persists it. Label is in Portuguese:
// shows the theme you would switch TO ("Claro" when dark, "Escuro" when light).
---

<button id="theme-toggle" type="button" aria-label="Alternar tema" transition:persist
>Tema</button>

<style>
  button {
    position: fixed;
    right: 2%;
    bottom: 3%;
    padding: 5px;
    width: 90px;
    height: 40px;
    color: #d4d4d4;
    font-size: 16px;
    border-radius: 10px 0 10px;
    background-color: var(--brand-purple);
    border: solid var(--accent);
    border-width: 0 1px;
    cursor: pointer;
    z-index: 1000;
  }

  button:hover {
    filter: drop-shadow(0 0 1em var(--shadow-color));
  }
</style>

<script>
  function labelForCurrent(): string {
    const isDark =
      document.documentElement.getAttribute("data-theme") === "dark";
    return isDark ? "Claro" : "Escuro";
  }

  function syncLabel(): void {
    const button = document.getElementById("theme-toggle");
    if (button) button.textContent = labelForCurrent();
  }

  function toggleTheme(): void {
    const root = document.documentElement;
    const next = root.getAttribute("data-theme") === "dark" ? "light" : "dark";
    root.setAttribute("data-theme", next);
    localStorage.setItem("theme", next);
    syncLabel();
  }

  document
    .getElementById("theme-toggle")
    ?.addEventListener("click", toggleTheme);
  syncLabel();
  // Re-sync after a View Transition swaps in a fresh button element.
  document.addEventListener("astro:after-swap", syncLabel);
</script>
