---
interface Props {
  href: string;
  title: string;
}

const { href, title } = Astro.props;
---

<div class="card-content">
  <div class="card">
    <a href={href}><strong>{title}</strong></a>
  </div>
</div>

<style>
  .card-content {
    background: linear-gradient(
      190deg,
      rgba(89, 25, 81, 0.6) 78%,
      rgba(2, 10, 88, 0.6) 76%
    );
    text-align: center;
    overflow: hidden;
  }

  .card {
    height: 250px;
    width: 300px;
    margin: 25px 30px;
    display: inline-block;
    white-space: normal;
    background: linear-gradient(
      150deg,
      rgba(2, 10, 88, 0.8) 76%,
      rgba(89, 25, 81, 0.8) 78%
    );
    transition: transform 0.2s ease-out;
  }

  .card:hover {
    transform: scale(1.03);
  }

  .card a {
    color: white;
    box-sizing: border-box;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    word-wrap: break-word;
    overflow: hidden;
    padding: 0 10%;
    height: 100%;
    width: 100%;
    text-align: center;
  }
</style>
