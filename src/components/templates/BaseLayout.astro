---
import { ClientRouter } from "astro:transitions";
import SiteHeader from "../organisms/SiteHeader.astro";
import SiteFooter from "../organisms/SiteFooter.astro";
import ProgressBar from "../atoms/ProgressBar.astro";
import ThemeToggle from "../atoms/ThemeToggle.astro";
import BackButton from "../atoms/BackButton.astro";
import "../../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="pt-br">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    {/* Apply theme before first paint to avoid a flash of the wrong theme. */}
    <script is:inline>
      (() => {
        const stored = localStorage.getItem("theme");
        const prefersDark =
          !window.matchMedia ||
          window.matchMedia("(prefers-color-scheme: dark)").matches;
        const theme = stored || (prefersDark ? "dark" : "light");
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
    <ClientRouter />
  </head>
  <body>
    <ProgressBar />
    <SiteHeader />
    <main>
      <slot />
    </main>
    <SiteFooter />
    <BackButton />
    <ThemeToggle />
  </body>
</html>

<script>
  // Re-apply the stored theme after each View Transition swap, since the
  // inline head script only runs on the initial document load.
  document.addEventListener("astro:after-swap", () => {
    const stored = localStorage.getItem("theme");
    if (stored) document.documentElement.setAttribute("data-theme", stored);
  });
</script>
