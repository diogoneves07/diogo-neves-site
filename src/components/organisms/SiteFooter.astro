---
import { links, profile } from "../../data/resume.ts";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container inner">
    <div class="location">
      <div>{profile.location}</div>
      <div>{profile.phone}</div>
    </div>

    <div class="copy">© {year} Diogo Neves · Desenvolvedor de Software</div>

    <nav aria-label="Links sociais">
      <a href={links.email}>{profile.email}</a>
      <a href={links.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <a href={links.github} target="_blank" rel="noopener noreferrer">GitHub</a>
      <a href={links.devto} target="_blank" rel="noopener noreferrer">dev.to</a>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    padding: var(--space-5) 0 var(--space-7);
  }

  .inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: var(--space-5);
    align-items: end;
  }

  .location,
  .copy,
  nav {
    font: var(--typography-caption);
    line-height: 1.9;
  }

  .location {
    color: var(--fg-dim);
  }

  .copy {
    color: var(--fg-faint);
    text-align: center;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: var(--space-4);
  }

  nav a {
    color: var(--fg-muted);
  }

  nav a:hover {
    color: var(--accent-bright);
  }

  @media (max-width: 840px) {
    .inner {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .copy,
    nav {
      text-align: left;
      justify-content: flex-start;
    }
  }
</style>
