---
import { getCollection, render } from "astro:content";
import {
  about,
  experienceIntro,
  experiences,
  links,
  profile,
  stackGroups,
  track,
} from "../../data/resume.ts";
import PortfolioSceneCanvas from "../molecules/PortfolioSceneCanvas.astro";
import TechChips from "../molecules/TechChips.astro";
import { formatArticleDate } from "../../lib/date.ts";
import PortfolioBottomNav from "./PortfolioBottomNav.astro";
import ArticleReadingSheet from "./ArticleReadingSheet.astro";
import { iconMarkup } from "../../data/icons.ts";

const articles = (await getCollection("articles")).sort(
  (a, b) => a.data.cardOrder - b.data.cardOrder
);

// Conteúdo MDX renderizado inline para alimentar o bottom-sheet de leitura.
const renderedArticles = await Promise.all(
  articles.map(async (article) => ({
    article,
    Content: (await render(article)).Content,
  }))
);

const navItems = [
  { href: "#sobre", label: "Sobre", icon: "user" as const },
  { href: "#experiencia", label: "Experiência", icon: "briefcase" as const },
  { href: "#artigos", label: "Artigos", icon: "pen" as const },
  { href: "#stack", label: "Tecnologias", icon: "chip" as const },
  { href: "#contato", label: "Contato", icon: "mail" as const },
];

const phoneDigits = profile.phone.replace(/\D/g, "");
const contactLinks = [
  { icon: "mail", label: profile.email, href: links.email, brand: false, solid: true, external: false },
  { icon: "whatsapp", label: profile.phone, href: `https://wa.me/${phoneDigits}`, brand: true, solid: false, external: true },
  { icon: "linkedin", label: "LinkedIn", href: links.linkedin, brand: true, solid: false, external: true },
  { icon: "github", label: "GitHub", href: links.github, brand: true, solid: false, external: true },
  { icon: "code", label: "DEV.to", href: links.devto, brand: false, solid: false, external: true },
];
---

<div class="portfolio-home" data-portfolio-home data-active-tone="city" data-active-focus="left">
  <PortfolioSceneCanvas />

  <PortfolioBottomNav
    leftItems={[navItems[0], navItems[1]]}
    centerItem={navItems[4]}
    rightItems={[navItems[2], navItems[3]]}
  />

  <section
    id="topo"
    class="chapter chapter-hero"
    data-scene-section
    data-scene-tone="city"
    data-scene-focus="left"
  >
    <div class="chapter-copy hero-copy" data-reveal>
      <h1 style="display: inline-block; background: #000;">Diogo Neves</h1>
      <p class="hero-summary" style="display: inline-block; background: #000;">{profile.description}</p>
      <svg
        class="hero-wave"
        viewBox="0 0 1200 120"
        preserveAspectRatio="none"
        aria-hidden="true"
        focusable="false"
      >
        <path
          d="M0 60 C 150 110, 300 10, 450 60 S 750 110, 900 60 S 1200 10, 1200 60 L 1200 120 L 0 120 Z"
        ></path>
      </svg>
    </div>
  </section>

  <section
    id="sobre"
    class="chapter chapter-slice chapter-slice-right"
    data-scene-section
    data-scene-tone="forest"
    data-scene-focus="center"
  >
    <div class="chapter-surface" data-reveal>
      <div class="surface-copy surface-copy-about">
        <p class="chapter-kicker">Sobre</p>
        <h2 class="about-title">{about.title}</h2>
        <p class="about-lead">{about.lead}</p>
        <p class="about-text">{about.paragraphs[0]}</p>
        <p class="about-text">{about.paragraphs[1]}</p>

        <div class="about-block">
          <p class="about-block-title">Domínios em que atuei</p>
          <ul class="icon-chips">
            {
              about.domains.map((domain) => (
                <li>
                  <span class="domain-icon" aria-hidden="true">{domain.icon}</span>
                  {domain.label}
                </li>
              ))
            }
          </ul>
        </div>

        <div class="about-block">
          <p class="about-block-title">Linguagens</p>
          <ul class="lang-list">
            {
              about.languages.map((lang) => {
                const slug = lang.icon.split("/").pop()!.replace(".svg", "");
                return (
                  <li style={`--lang-color:${lang.color}`}>
                    <img
                      class={`lang-icon lang-icon-${slug}`}
                      src={lang.icon}
                      alt=""
                      aria-hidden="true"
                      width="36"
                      height="36"
                      loading="lazy"
                    />
                    {lang.name}
                  </li>
                );
              })
            }
          </ul>
        </div>
      </div>
    </div>

    <aside class="track-panel" data-reveal>
      <p class="chapter-kicker">Trajetória</p>
      <div class="track-countries">
        {
          track.countries.map((country) => (
            <span class="track-flag">
              <span aria-hidden="true">{country.flag}</span>
              {country.name}
            </span>
          ))
        }
      </div>
      <p class="track-subtitle">Projetos de destaque</p>
      <ul class="track-list">
        {
          track.flagships.map((flagship) => (
            <li>
              <strong>{flagship.name}</strong>
              <span>{flagship.note}</span>
            </li>
          ))
        }
      </ul>
    </aside>
  </section>

  <section
    id="experiencia"
    class="chapter chapter-slice chapter-slice-left"
    data-scene-section
    data-scene-tone="forest"
    data-scene-focus="right"
  >
    <div class="chapter-surface" data-reveal>
      <div class="surface-copy surface-copy-about">
        <p class="chapter-kicker">Experiência</p>
        <h2 class="about-title">{experienceIntro.title}</h2>
        <p class="about-text">{experienceIntro.lead}</p>

        <ul class="icon-chips">
          {
            experienceIntro.signals.map((signal) => (
              <li>
                <span class="domain-icon" aria-hidden="true">{signal.icon}</span>
                {signal.label}
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div class="experience-stack" data-reveal>
      {
        experiences.map((item) => (
          <article class={`story-card ${item.current ? "story-card-current" : ""}`}>
            <div class="story-head">
              <span class="story-icon" aria-hidden="true">{item.icon}</span>
              <div class="story-meta">
                <span class="story-period">{item.period}</span>
                {item.current && <span class="story-badge">Atual</span>}
              </div>
            </div>
            <h3>{item.role}</h3>
            <p class="story-company">
              {item.company}
              {item.location ? ` · ${item.location}` : ""}
            </p>
            <p>{item.summary}</p>
            {item.highlights && (
              <ul class="story-highlights">
                {item.highlights.map((highlight) => <li>{highlight}</li>)}
              </ul>
            )}
            {item.stack && <TechChips items={item.stack} />}
          </article>
        ))
      }
    </div>
  </section>

  <section
    id="artigos"
    class="chapter chapter-slice chapter-slice-left"
    data-scene-section
    data-scene-tone="lake"
    data-scene-focus="center"
  >
    <div class="chapter-surface chapter-surface-notes" data-reveal>
      <div class="surface-copy surface-copy-about">
        <p class="chapter-kicker">Artigos</p>
        <h2 class="about-title">Notas técnicas, produto e opinião escrita sem suavizar o raciocínio.</h2>
      </div>
    </div>

    <div class="article-grid" data-reveal>
      {
        articles.map((article) => (
          <a class="article-card" href={`#leitura-${article.id}`} data-article-link>
            <div class="story-head">
              <span class="story-icon" aria-hidden="true">✍️</span>
              <div class="story-meta">
                <span class="story-period">{formatArticleDate(article.data.updated)}</span>
              </div>
            </div>
            <h3>{article.data.title}</h3>
            <p>{article.data.excerpt}</p>
            <TechChips items={article.data.tags} />
            <span class="article-cta" aria-hidden="true">
              Ler artigo
              <span class="article-cta__arrow">→</span>
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <section
    id="stack"
    class="chapter chapter-slice chapter-slice-left"
    data-scene-section
    data-scene-tone="tech"
    data-scene-focus="center"
  >
    <div class="chapter-surface chapter-surface-notes" data-reveal>
      <div class="surface-copy surface-copy-about">
        <p class="chapter-kicker">Tecnologias</p>
        <h2 class="about-title">Tecnologias com as quais me sinto confortável trabalhando:</h2>
      </div>
    </div>

    <div class="stack-columns" data-reveal>
      {
        stackGroups.map((group) => (
          <article class="stack-card">
            <p class="stack-title">{group.category}</p>
            <TechChips items={group.items} />
          </article>
        ))
      }
    </div>
  </section>

  <section
    id="contato"
    class="chapter chapter-slice chapter-slice-left"
    data-scene-section
    data-scene-tone="tech"
    data-scene-focus="left"
  >
    <div class="chapter-surface chapter-surface-notes" data-reveal>
      <div class="surface-copy surface-copy-about">
        <p class="chapter-kicker">Contato</p>
        <h2 class="about-title">Disponível para novos projetos, colaborações e conversas técnicas.</h2>
      </div>
    </div>

    <aside class="contact-panel" data-reveal>
      <div class="contact-links">
        {
          contactLinks.map((item) => (
            <a
              class={`pill-button contact-pill ${item.solid ? "pill-button-solid" : ""}`}
              href={item.href}
              {...(item.external ? { target: "_blank", rel: "noreferrer" } : {})}
            >
              <svg
                class={`contact-icon ${item.brand ? "contact-icon-brand" : ""}`}
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <g set:html={iconMarkup[item.icon as keyof typeof iconMarkup]} />
              </svg>
              {item.label}
            </a>
          ))
        }
      </div>
    </aside>
  </section>

  <ArticleReadingSheet articles={renderedArticles} />
</div>

<script>
  const disposers = new Set<() => void>();

  const cleanup = () => {
    disposers.forEach((dispose) => dispose());
    disposers.clear();
  };

  const init = async () => {
    cleanup();

    const root = document.querySelector<HTMLElement>("[data-portfolio-home]");
    if (!root) {
      return;
    }

    // Navegação e scroll são essenciais e leves — inicializam primeiro e
    // independentes da cena 3D, para que uma falha ao carregar o three.js
    // (rede, WebGL indisponível) nunca derrube o menu.
    const [{ setupPortfolioScroll }, { setupPortfolioNav }, { setupArticleSheet }] =
      await Promise.all([
        import("../molecules/portfolio-scroll"),
        import("../molecules/portfolio-nav"),
        import("../molecules/article-sheet"),
      ]);

    disposers.add(setupPortfolioScroll(root));
    disposers.add(setupPortfolioNav(root));
    disposers.add(setupArticleSheet(root));

    // Cena pesada e opcional: carregada à parte, com falha isolada.
    // Navegadores automatizados (Playwright/Selenium marcam navigator.webdriver)
    // não se beneficiam do fundo 3D decorativo — e a cena estrangula a main
    // thread, tornando flaky os testes de UI. Pulamos a montagem nesse caso.
    if (!navigator.webdriver) {
      import("../molecules/scene")
        .then(({ mountPortfolioScene }) => disposers.add(mountPortfolioScene(root)))
        .catch((error) => console.error("Falha ao montar a cena do portfólio", error));
    }
  };

  init();
  document.addEventListener("astro:page-load", init);
  document.addEventListener("astro:before-swap", cleanup);
</script>

<style>
  .portfolio-home {
    position: relative;
    z-index: 1;
    color: var(--fg);
  }

  .chapter {
    position: relative;
    min-height: 100vh;
    padding:
      clamp(4.5rem, 12vw, 7rem)
      clamp(1.25rem, 4vw, 2.25rem)
      calc(var(--mobile-bottom-nav-height) + clamp(2.5rem, 8vw, 4rem));
    display: grid;
    align-items: center;
  }

  .chapter-hero {
    min-height: 112vh;
    align-items: start;
    padding-top: 0;
    padding-bottom: clamp(2.5rem, 8vw, 4rem);
  }

  .chapter-copy.hero-copy {
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    max-width: none;
    width: auto;
    margin-top: 40px;
    padding: clamp(1.75rem, 4vw, 2.75rem);
    padding-top: clamp(0.4375rem, 1vw, 0.6875rem);
    border-radius: 0;
    border: 0;
    background: transparent;
    backdrop-filter: none;
  }

  .hero-copy h1,
  .hero-copy .hero-summary {
    position: relative;
    z-index: 1;
  }

  .hero-copy h1 {
    color: #ffffff;
    white-space: nowrap;
    font-size: clamp(1.9rem, 5.5vw, 4.4rem);
    margin-top: 0;
    line-height: 0.7;
    text-shadow: 0 3px 18px rgba(0, 0, 0, 0.55);
  }

  /* Marca de acento antes do nome */
  .hero-copy h1::before {
    content: "";
    display: block;
    width: clamp(40px, 6vw, 72px);
    height: 4px;
    margin-bottom: clamp(0.75rem, 1.6vw, 1.1rem);
    border-radius: 999px;
    background: linear-gradient(90deg, #ffffff, rgba(255, 255, 255, 0.1));
  }

  .hero-copy .hero-summary {
    color: rgba(255, 255, 255, 0.92);
    margin-top: var(--space-5);
    margin-bottom: 30px;
    text-shadow: 0 2px 14px rgba(0, 0, 0, 0.6);
  }

  /* Onda decorativa na base do container */
  .hero-wave {
    position: absolute;
    left: 0;
    bottom: -1px;
    z-index: 0;
    width: 100%;
    height: clamp(48px, 7vw, 84px);
    pointer-events: none;
  }

  .hero-wave path {
    fill: transparent;
    stroke: transparent;
    stroke-width: 1.5;
  }

  .chapter-copy,
  .chapter-surface,
  .track-panel,
  .experience-stack,
  .article-grid,
  .stack-columns,
  .contact-panel {
    opacity: 0;
    transform: translateY(36px);
    transition:
      opacity 0.7s var(--ease),
      transform 0.8s var(--ease);
  }

  [data-revealed="true"] {
    opacity: 1;
    transform: translateY(0);
  }

  .chapter-copy {
    max-width: min(760px, 100%);
    margin-inline: auto;
    text-align: center;
  }

  .chapter-kicker,
  .story-period,
  .stack-title {
    font: var(--typography-kicker);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-dim);
  }

  h1,
  h2,
  h3 {
    color: #0f1217;
  }

  h1 {
    font-size: clamp(3.8rem, 11vw, 8.8rem);
    line-height: 0.92;
    font-weight: 800;
    letter-spacing: -0.04em;
  }

  h2 {
    font-size: clamp(2.5rem, 6vw, 5rem);
    line-height: 0.98;
    letter-spacing: -0.03em;
  }

  h3 {
    font-size: clamp(1.5rem, 2.2vw, 2rem);
    line-height: 1.12;
  }

  .hero-summary,
  .surface-copy p,
  .story-card p,
  .article-card p,
  .contact-panel p {
    color: rgba(15, 18, 23, 0.82);
    font: var(--typography-body);
  }

  .hero-summary {
    max-width: 56rem;
    margin: var(--space-4) auto 0;
    font: var(--typography-body-large);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    justify-content: center;
    margin-top: var(--space-5);
  }

  .chapter-slice {
    grid-template-columns: minmax(0, 1.05fr) minmax(280px, 440px);
    gap: clamp(1.5rem, 5vw, 3.25rem);
  }

  .chapter-slice-left {
    grid-template-columns: minmax(280px, 440px) minmax(0, 1.05fr);
  }

  .chapter-surface {
    position: relative;
    padding: clamp(2.375rem, 5vw, 3.5rem);
    background: rgba(246, 241, 232, 0.82);
    backdrop-filter: blur(18px);
    border: 1px solid rgba(15, 18, 23, 0.08);
    clip-path: polygon(0 14%, 85% 0, 100% 18%, 100% 100%, 0 100%);
  }

  .chapter-slice-left .chapter-surface {
    clip-path: polygon(0 0, 100% 12%, 100% 100%, 16% 100%, 0 78%);
  }

  /* Mesmo layout da Experiência (painel estreito à esquerda, cards largos
     à direita). Contorno próprio para não ficar 100% igual. */
  .chapter-surface-notes {
    clip-path: polygon(0 8%, 88% 0, 100% 14%, 100% 82%, 84% 100%, 0 100%);
  }

  .surface-copy {
    display: grid;
    gap: var(--space-4);
    max-width: 38rem;
  }

  .track-panel,
  .contact-panel,
  .stack-card,
  .story-card,
  .article-card {
    border: 1px solid rgba(15, 18, 23, 0.1);
    background: rgba(248, 244, 235, 0.72);
    backdrop-filter: blur(18px);
  }

  /* ---- Seção Sobre: resumo organizado ---- */
  .surface-copy-about {
    max-width: 42rem;
  }

  .about-title {
    margin-top: clamp(0.75rem, 2vw, 1.5rem);
    font-size: clamp(1.75rem, 3.4vw, 2.5rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-weight: 700;
  }

  .about-lead {
    font: var(--typography-section-title);
    font-size: var(--text-xl);
    color: #11141a;
  }

  .about-text {
    font: var(--typography-body);
    color: rgba(15, 18, 23, 0.82);
  }

  .about-block {
    display: grid;
    gap: var(--space-3);
  }

  .about-block-title {
    font: var(--typography-kicker);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-dim);
  }

  .icon-chips,
  .lang-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    padding: 0;
    margin: 0;
  }

  .icon-chips li,
  .lang-list li {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border-radius: 999px;
    padding: 0.4375rem 0.8125rem;
    border: 1px solid rgba(15, 18, 23, 0.12);
    background: rgba(255, 255, 255, 0.52);
    font: var(--typography-label);
    color: #11141a;
  }

  .domain-icon {
    font-size: 1rem;
    line-height: 1;
  }

  /* Dobro do tamanho anterior; altura uniforme mantém os chips nivelados.
     A largura varia por logo para compensar o desenho dentro do viewBox. */
  .lang-icon {
    width: 2.25rem;
    height: 2.25rem;
    display: block;
    object-fit: contain;
  }

  /* PHP é uma elipse larga e baixa: alarga a caixa e corta o espaço vazio
     vertical (cover) para o glifo ler no mesmo peso visual dos demais. */
  .lang-icon-php {
    width: 3rem;
    object-fit: cover;
  }

  /* Dart é levemente mais estreito/diagonal — ganha um respiro extra. */
  .lang-icon-dart {
    width: 2.5rem;
  }

  .lang-list li {
    border-color: color-mix(in srgb, var(--lang-color, #11141a) 35%, rgba(15, 18, 23, 0.12));
    background: color-mix(in srgb, var(--lang-color, #11141a) 8%, rgba(255, 255, 255, 0.52));
  }

  /* ---- Painel lateral: Trajetória ---- */
  .track-panel {
    padding: var(--space-5);
    align-self: center;
    display: grid;
    gap: var(--space-4);
  }

  .track-countries {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .track-flag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border-radius: 999px;
    padding: 0.375rem 0.75rem;
    border: 1px solid rgba(15, 18, 23, 0.12);
    background: rgba(255, 255, 255, 0.52);
    font: var(--typography-label);
    color: #11141a;
  }

  .track-flag span {
    font-size: 1.05rem;
    line-height: 1;
  }

  .track-subtitle {
    font: var(--typography-kicker);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-dim);
    margin: 0;
  }

  .track-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-4);
  }

  .track-list li {
    display: grid;
    gap: 0.25rem;
    padding-left: var(--space-4);
    border-left: 2px solid rgba(15, 18, 23, 0.16);
  }

  .track-list strong {
    color: #11141a;
    font-size: var(--text-base);
    line-height: 1.2;
  }

  .track-list span {
    color: rgba(15, 18, 23, 0.66);
    font: var(--typography-body-small);
  }

  .experience-stack,
  .article-grid,
  .stack-columns {
    display: grid;
    gap: var(--space-4);
  }

  .experience-stack,
  .article-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .story-card,
  .article-card,
  .stack-card,
  .contact-panel {
    padding: var(--space-5);
  }

  .story-card {
    transform: translateY(calc((0.5 - var(--section-progress, 0.5)) * 26px));
  }

  .story-card,
  .article-card {
    display: grid;
    gap: var(--space-3);
  }

  /* ---- Card de artigo: affordance de clique ---- */
  .article-card {
    align-content: start;
    color: inherit;
    text-decoration: none;
    cursor: pointer;
    transition:
      transform 0.25s var(--ease),
      box-shadow 0.25s var(--ease),
      border-color 0.25s var(--ease);
  }

  .article-card:hover,
  .article-card:focus-visible {
    transform: translateY(-4px);
    border-color: rgba(15, 18, 23, 0.28);
    box-shadow: 0 18px 40px rgba(15, 18, 23, 0.16);
  }

  .article-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: var(--space-2);
    font: var(--typography-label);
    font-weight: 600;
    color: #0f1217;
  }

  .article-cta__arrow {
    transition: transform 0.25s var(--ease);
  }

  .article-card:hover .article-cta__arrow,
  .article-card:focus-visible .article-cta__arrow {
    transform: translateX(4px);
  }

  .story-company {
    font-weight: 600;
  }

  /* ---- Cards de experiência enriquecidos ---- */
  .story-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .story-icon {
    display: grid;
