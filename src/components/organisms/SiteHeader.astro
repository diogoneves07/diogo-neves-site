---
// Top banner. The angled "strange-shape" is a decorative brand element
// carried over from the original site.
---

<div class="site-header">
  <header>
    <div>
      <strong>Devs.has(“diogoneves07”)</strong>
    </div>
  </header>
  <div class="strange-shape"></div>
</div>

<style>
  .site-header {
    color: #ededed;
    padding: 5px 0;
  }

  header > div {
    background: linear-gradient(
      190deg,
      var(--brand-purple) 78%,
      var(--brand-blue) 76%
    );
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 15px 0;
  }

  header strong {
    font-size: 20px;
    cursor: help;
  }

  @keyframes anime-shape {
    0% {
      clip-path: polygon(0% -100%, 50% 100%, 100% 0%);
    }
    100% {
      clip-path: polygon(0% -100%, 20% 100%, 100% 0%);
    }
  }

  .strange-shape {
    clip-path: polygon(0% -100%, 20% 100%, 100% 0%);
    position: relative;
    bottom: -5px;
    background: linear-gradient(
      90deg,
      var(--brand-magenta) 28%,
      var(--brand-deep-blue) 76%
    );
    height: 35px;
    width: 100%;
    animation: anime-shape cubic-bezier(0.68, -0.55, 0.265, 1.55) 2s forwards;
  }
</style>
