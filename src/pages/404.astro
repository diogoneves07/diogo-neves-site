---
import BaseLayout from "../components/templates/BaseLayout.astro";
---

<BaseLayout title="Diogo Neves | Página não encontrada">
  <div class="not-found">
    <h2>Página não encontrada! :(</h2>
    <a href="/">Início</a>
  </div>
</BaseLayout>

<style>
  .not-found {
    height: 200px;
    display: grid;
    justify-content: center;
    align-items: center;
    text-align: center;
  }

  .not-found a {
    display: inline-block;
    width: 200px;
    height: 50px;
    line-height: 50px;
    font-size: 18px;
    margin-top: 20px;
    text-decoration: none;
    background-color: transparent;
    border: 1px solid currentColor;
    border-radius: 10px 0 10px;
  }
</style>
