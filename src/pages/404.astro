---
import BaseLayout from "../components/templates/BaseLayout.astro";
---

<BaseLayout title="Diogo Neves | Página não encontrada" showBackButton={true}>
  <section class="not-found">
    <p class="prose-kicker">404</p>
    <h1>Página não encontrada.</h1>
    <p>
      O endereço que você tentou abrir não existe mais ou foi movido durante a
      reconstrução do portfólio.
    </p>
    <a href="/">Voltar ao início</a>
  </section>
</BaseLayout>
